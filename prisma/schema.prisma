generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Video {
  id        String   @id @default(cuid())
  title     String
  url       String
  thumbnail String?
  duration  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
